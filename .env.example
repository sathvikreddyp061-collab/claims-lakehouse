# Kafka / Redpanda
KAFKA_BOOTSTRAP=localhost:19092
KAFKA_BOOTSTRAP_INTERNAL=redpanda:9092

# Topics
TOPIC_CLAIM=claims.edi837.v1
TOPIC_ELIG=eligibility.v1
TOPIC_MEMBER=member.events.v1

# MinIO (S3 lake)
S3_ENDPOINT=http://localhost:9000
S3_ENDPOINT_INTERNAL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lakehouse

# Iceberg
ICEBERG_CATALOG=lakehouse
ICEBERG_WAREHOUSE=s3a://lakehouse/warehouse

# Postgres (Vercel mirror)
POSTGRES_URL=postgresql://claims:claims@localhost:5432/claims

# DuckDB (warehouse)
DUCKDB_PATH=./data/duckdb/claims.duckdb

# Synthea
SYNTHEA_POPULATION=10000
SYNTHEA_HORIZON_YEARS=2
SYNTHEA_SEED=20260516

# Producer
EVENTS_PER_SECOND=1000

# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
